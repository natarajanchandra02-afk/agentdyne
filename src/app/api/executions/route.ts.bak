import { NextRequest, NextResponse } from "next/server"
import { createClient } from "@/lib/supabase/server"
import { apiRateLimit } from "@/lib/rate-limit"

async function resolveUserId(req: NextRequest): Promise<string | null> {
  const supabase = createClient()
  const { data: { user } } = await supabase.auth.getUser()
  if (user?.id) return user.id

  const rawKey =
    req.headers.get("authorization")?.replace(/^Bearer\s+/i, "") ??
    req.headers.get("x-api-key")
  if (!rawKey) return null

  const buf  = await crypto.subtle.digest("SHA-256", new TextEncoder().encode(rawKey))
  const hash = Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, "0")).join("")

  const { data: keyRow } = await supabase
    .from("api_keys")
    .select("user_id, is_active")
    .eq("key_hash", hash)
    .single()

  if (!keyRow?.is_active) return null
  return keyRow.user_id
}

/**
 * GET /v1/executions
 * List the authenticated user's executions.
 * Query params: agentId, status, since, page, limit
 */
export async function GET(req: NextRequest) {
  const limited = await apiRateLimit(req)
  if (limited) return limited

  try {
    const supabase = createClient()
    const userId   = await resolveUserId(req)
    if (!userId) return NextResponse.json({ error: "Unauthorized" }, { status: 401 })

    const { searchParams } = new URL(req.url)
    const agentId = searchParams.get("agentId")
    const status  = searchParams.get("status")
    const since   = searchParams.get("since")
    const page    = Math.max(1, parseInt(searchParams.get("page")  || "1"))
    const limit   = Math.min(100, Math.max(1, parseInt(searchParams.get("limit") || "20")))

    let query = supabase
      .from("executions")
      .select(
        `id, agent_id, user_id, status, input, output, error_message,
         tokens_input, tokens_output, latency_ms, cost, created_at, completed_at,
         agents!agent_id(id, name, icon_url)`,
        { count: "exact" }
      )
      .eq("user_id", userId)
      .order("created_at", { ascending: false })

    if (agentId) query = (query as any).eq("agent_id", agentId)
    if (status)  query = (query as any).eq("status", status)
    if (since)   query = (query as any).gte("created_at", since)

    query = (query as any).range((page - 1) * limit, page * limit - 1)

    const { data, count, error } = await query
    if (error) throw error

    const total = count ?? 0
    const pages = Math.ceil(total / limit)

    return NextResponse.json({
      data: data ?? [],
      pagination: {
        total,
        page,
        limit,
        pages,
        hasNext: page < pages,
        hasPrev: page > 1,
      },
    })
  } catch (err: any) {
    console.error("GET /api/executions:", err)
    return NextResponse.json({ error: err.message }, { status: 500 })
  }
}
