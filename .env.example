# ============================================================
# AgentDyne Platform — Environment Variables
# Last updated: April 2026 | Migration 012 (Launch Hardening)
# ============================================================
# Copy to .env.local (local dev) or add to:
#   Cloudflare Pages → project → Settings → Environment Variables
#
# REQUIRED AT MINIMUM (12 vars for full launch):
#   NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY,
#   SUPABASE_SERVICE_ROLE_KEY, ANTHROPIC_API_KEY,
#   NEXT_PUBLIC_APP_URL, STRIPE_SECRET_KEY,
#   STRIPE_WEBHOOK_SECRET, STRIPE_STARTER_PRICE_ID,
#   STRIPE_PRO_PRICE_ID, NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY,
#   SLACK_WEBHOOK_URL (strongly recommended)
# ============================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://agentdyne.com
NEXT_PUBLIC_APP_VERSION=1.0.0

# ── AI Providers ──────────────────────────────────────────────────────────────
# Start with Anthropic only. Add others when sellers need them.
# Without a key, agents using that provider return a clear 503 error.

# REQUIRED — Claude Sonnet/Haiku/Opus
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL — GPT-4o/mini agents + RAG embeddings (text-embedding-3-small)
# Without this: GPT agents fail, RAG falls back to keyword-only search
# Get from: platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# OPTIONAL — Gemini 1.5 Pro/Flash agents
# Get from: aistudio.google.com → API Keys
GOOGLE_AI_API_KEY=AIza...

# OPTIONAL — Self-hosted vLLM cluster (OpenAI-compatible)
# VLLM_BASE_URL=https://your-vllm-cluster.internal

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
# Use sk_test_ for development, sk_live_ for production

STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Get from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# Endpoint URL: https://agentdyne.com/api/webhooks/stripe
# Events: checkout.session.completed, customer.subscription.*, invoice.payment_*, charge.refunded, account.updated
STRIPE_WEBHOOK_SECRET=whsec_...

# Create in Stripe Dashboard → Products → Add Product → Recurring → Monthly
STRIPE_STARTER_PRICE_ID=price_...   # $19/month → 1,000 quota
STRIPE_PRO_PRICE_ID=price_...       # $79/month → 10,000 quota

# ── Monitoring & Alerting ─────────────────────────────────────────────────────
# Without these you won't know the platform is down until a user tweets.

# Slack webhook (2 min setup) — fires on 5xx errors, abuse events, billing failures
# Create: api.slack.com/apps → New App → Incoming Webhooks → Add to Workspace
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Better Stack heartbeat (free) — 30s uptime check on /api/health
# Create: betterstack.com → Uptime → New Monitor → Heartbeat → copy URL
BETTER_STACK_HEARTBEAT_URL=https://uptime.betterstack.com/api/v1/heartbeat/xxx

# Sentry DSN (free 5000 errors/month) — structured error tracking
# Create: sentry.io → New Project → Next.js → copy DSN
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Admin alert email (billing anomalies, large abuse events)
ADMIN_ALERT_EMAIL=founder@agentdyne.com

# ── Email (Transactional) ─────────────────────────────────────────────────────
# For email verification, password reset, notifications
# Supabase handles auth emails by default. Use Resend for custom templates.
# RESEND_API_KEY=re_...

# ── Security ──────────────────────────────────────────────────────────────────
# MAINTENANCE_MODE=false    # Set to "true" to show maintenance page globally
# NEXT_PUBLIC_LAUNCH_MODE=live  # "live" removes beta banners

# ── Setup Checklist ───────────────────────────────────────────────────────────
# Minimum for agents to work:
#   [ ] NEXT_PUBLIC_SUPABASE_URL + ANON_KEY + SERVICE_ROLE_KEY
#   [ ] ANTHROPIC_API_KEY
#   [ ] NEXT_PUBLIC_APP_URL
#
# Required for full platform (billing + subscriptions):
#   [ ] STRIPE_SECRET_KEY
#   [ ] STRIPE_WEBHOOK_SECRET  (+ register endpoint in Stripe Dashboard)
#   [ ] STRIPE_STARTER_PRICE_ID + STRIPE_PRO_PRICE_ID
#   [ ] NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
#
# Strongly recommended for launch:
#   [ ] SLACK_WEBHOOK_URL          (you need this — you WILL be blind without it)
#   [ ] BETTER_STACK_HEARTBEAT_URL (30s uptime checks, free)
#   [ ] OPENAI_API_KEY             (RAG + GPT agents)
#
# Before going live:
#   [ ] Run migrations 010, 011, 012 in Supabase SQL Editor (in order)
#   [ ] Verify pg_cron jobs in Supabase → Database → Extensions → pg_cron
#   [ ] Switch Stripe from test to live mode
#   [ ] Add SPF/DKIM/DMARC DNS records for your domain
#   [ ] Test /api/health returns 200 with database: true
