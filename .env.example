# ============================================================
# AgentDyne Platform — Environment Variables
# Copy this to .env.local and fill in your values.
# Variables marked REQUIRED must be set before the app will work.
# Variables marked OPTIONAL can be added when you're ready for that feature.
# ============================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
# REQUIRED — get from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ────────────────────────────────────────────────────────────────────
# REQUIRED — billing + seller payouts
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Subscription price IDs (Stripe Dashboard → Products → each plan → Price ID)
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# ── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://agentdyne.com
NEXT_PUBLIC_APP_NAME=AgentDyne

# ── AI Providers ──────────────────────────────────────────────────────────────

# REQUIRED — Anthropic Claude (primary AI runtime)
ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL — OpenAI GPT-4o / GPT-4o-mini agents + RAG embeddings
# Without this: agents using gpt-* models will fail, and RAG/semantic search won't work
OPENAI_API_KEY=sk-...

# OPTIONAL — Google Gemini 1.5 Pro / Flash agents
# Without this: agents using gemini-* models will fail
GOOGLE_AI_API_KEY=AIza...

# OPTIONAL — Self-hosted vLLM cluster (OpenAI-compatible endpoint)
# Set agent model_name in the builder as "vllm/your-model-name"
# VLLM_BASE_URL=https://your-vllm-cluster.internal

# ── Internal Security ─────────────────────────────────────────────────────────
# REQUIRED — server-to-server auth secret (minimum 32 chars, use a UUID or random string)
INTERNAL_API_SECRET=generate-a-random-32-char-string-here

# ── Email (Resend) ────────────────────────────────────────────────────────────
# OPTIONAL — transactional email (password reset, billing receipts)
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@agentdyne.com

# ── Cloudflare Pages Deployment Notes ────────────────────────────────────────
# When deploying to Cloudflare Pages, add all vars above in:
#   Cloudflare Dashboard → Pages → your-project → Settings → Environment Variables
#
# Cloudflare does NOT read .env files from the repository.
# For local wrangler dev: add vars to .dev.vars (git-ignored by default)
# Example .dev.vars:
#   ANTHROPIC_API_KEY=sk-ant-...
#   NEXT_PUBLIC_SUPABASE_URL=https://...
