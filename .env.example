# ============================================================
# AgentDyne Platform — Environment Variables
# ============================================================
# Copy this file to .env.local (local dev) or add to:
#   Cloudflare Pages → project → Settings → Environment Variables
#
# BUSINESS MODEL NOTE:
#   AgentDyne holds ONE set of API keys — the platform's own.
#   Users never need their own LLM keys. You pay the LLM providers
#   directly and charge users via subscriptions + per-call credits.
#   Start with just ANTHROPIC_API_KEY. Add others when sellers need them.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
# REQUIRED — get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# ── App URL ───────────────────────────────────────────────────────────────────
# REQUIRED — used for Stripe redirects and email links
NEXT_PUBLIC_APP_URL=https://agentdyne.com

# ── AI PROVIDERS ─────────────────────────────────────────────────────────────
# You only NEED the keys for models you want to support.
# Start with Anthropic — it covers Claude Sonnet, Haiku, Opus.
# Without a key, agents using that provider return a clear 503 error.

# REQUIRED to run any Claude agent (most agents will use this)
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL — enables GPT-4o/mini agents + RAG embeddings (text-embedding-3-small)
# Without this: GPT agents fail, RAG/semantic search falls back to keyword-only
# Get from: platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# OPTIONAL — enables Gemini 1.5 Pro/Flash agents
# Without this: Gemini agents return 503
# Get from: aistudio.google.com → API Keys
GOOGLE_AI_API_KEY=AIza...

# OPTIONAL — self-hosted vLLM cluster (OpenAI-compatible endpoint)
# Set agent model_name in the builder as "vllm/your-model-name"
# VLLM_BASE_URL=https://your-vllm-cluster.internal

# ── Stripe ────────────────────────────────────────────────────────────────────
# REQUIRED for billing. Without these, subscriptions and credits won't work.
# Get from: dashboard.stripe.com → Developers → API Keys

STRIPE_SECRET_KEY=sk_live_...           # or sk_test_... for development
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...         # Stripe Dashboard → Webhooks → your endpoint → Signing secret

# Create these products in Stripe Dashboard → Products:
# "Starter Plan" → Monthly → $19 → copy Price ID below
STRIPE_STARTER_PRICE_ID=price_...
# "Pro Plan" → Monthly → $79 → copy Price ID below
STRIPE_PRO_PRICE_ID=price_...

# ── Stripe Webhook Setup ──────────────────────────────────────────────────────
# Register this URL in Stripe Dashboard → Developers → Webhooks → Add endpoint:
#   URL: https://agentdyne.com/api/webhooks/stripe
#   Events to listen for:
#     checkout.session.completed
#     customer.subscription.created
#     customer.subscription.updated
#     customer.subscription.deleted
#     invoice.payment_succeeded
#     invoice.payment_failed
#     charge.refunded
#     account.updated

# ── Setup Checklist ───────────────────────────────────────────────────────────
# Minimum to get agents working:
#   [ ] NEXT_PUBLIC_SUPABASE_URL
#   [ ] NEXT_PUBLIC_SUPABASE_ANON_KEY
#   [ ] SUPABASE_SERVICE_ROLE_KEY
#   [ ] ANTHROPIC_API_KEY
#   [ ] NEXT_PUBLIC_APP_URL
#
# Additional for full platform:
#   [ ] OPENAI_API_KEY          (RAG + GPT agents)
#   [ ] STRIPE_SECRET_KEY       (billing)
#   [ ] STRIPE_WEBHOOK_SECRET   (subscription events)
#   [ ] STRIPE_STARTER_PRICE_ID (Starter plan)
#   [ ] STRIPE_PRO_PRICE_ID     (Pro plan)
